<%- include('partials/header') %>

<!-- PAGE HEADER -->
<section class="bg-navy-900 text-white pt-16 pb-16 px-6 text-center">
  <p class="text-amber-200 text-sm font-medium tracking-widest uppercase mb-3">Pricing</p>
  <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-3">Simple, transparent rates</h1>
  <p class="text-navy-100 max-w-xl mx-auto text-sm sm:text-base">No hidden fees. No surprises. Just one-on-one sessions billed fairly.</p>
</section>

<!-- PRICING CARDS -->
<section class="py-16 px-6 bg-white">
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

    <!-- Hourly -->
    <div class="border border-navy-100 rounded-2xl p-6 reveal flex flex-col">
      <p class="text-amber-400 text-xs font-medium tracking-widest uppercase mb-2">Pay as you go</p>
      <h2 class="font-semibold text-navy-900 text-base mb-1">Hourly session</h2>
      <p class="font-display text-3xl font-bold text-navy-900 mb-1">R130 <span class="text-sm text-gray-400 font-normal">/hr</span></p>
      <p class="text-gray-500 text-xs mb-4">Per student, per session.</p>
      <ul class="space-y-2 text-xs text-gray-600 mb-6 flex-1">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Any subject, Grades 8–12
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          No commitment
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Pay per session
        </li>
      </ul>
      <a href="/book" class="block w-full text-center bg-navy-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-navy-800 transition-colors">Book a session</a>
    </div>

    <!-- 4-session package -->
    <div class="border border-navy-100 rounded-2xl p-6 reveal flex flex-col">
      <p class="text-amber-400 text-xs font-medium tracking-widest uppercase mb-2">Package</p>
      <h2 class="font-semibold text-navy-900 text-base mb-1">4-session pack</h2>
      <p class="font-display text-3xl font-bold text-navy-900 mb-1">R494 <span class="text-sm text-gray-400 font-normal">total</span></p>
      <p class="text-gray-500 text-xs mb-4">R123.50/hr — save R26.</p>
      <ul class="space-y-2 text-xs text-gray-600 mb-6 flex-1">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          4 one-hour sessions
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Good for a short-term push
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Use at your own pace
        </li>
      </ul>
      <a href="/book?plan=4-pack" class="block w-full text-center bg-navy-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-navy-800 transition-colors">Get this pack</a>
    </div>

    <!-- 8-session package -->
    <div class="border-2 border-amber-200 rounded-2xl p-6 relative reveal flex flex-col">
      <span class="absolute -top-3 left-6 bg-amber-200 text-amber-900 text-xs font-medium px-3 py-1 rounded-full">Best value</span>
      <p class="text-amber-400 text-xs font-medium tracking-widest uppercase mb-2">Package</p>
      <h2 class="font-semibold text-navy-900 text-base mb-1">8-session pack</h2>
      <p class="font-display text-3xl font-bold text-navy-900 mb-1">R960 <span class="text-sm text-gray-400 font-normal">total</span></p>
      <p class="text-gray-500 text-xs mb-4">R120/hr — save R80.</p>
      <ul class="space-y-2 text-xs text-gray-600 mb-6 flex-1">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          8 one-hour sessions
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Pay once, book flexibly
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Best for ongoing weekly support
        </li>
      </ul>
      <a href="/book?plan=8-pack" class="block w-full text-center bg-amber-200 text-amber-900 px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-amber-100 transition-colors">Get this pack</a>
    </div>

    <!-- Group sessions -->
    <div class="border border-navy-100 rounded-2xl p-6 reveal flex flex-col">
      <p class="text-amber-400 text-xs font-medium tracking-widest uppercase mb-2">Small group</p>
      <h2 class="font-semibold text-navy-900 text-base mb-1">Group session</h2>
      <p class="font-display text-3xl font-bold text-navy-900 mb-1">R110 <span class="text-sm text-gray-400 font-normal">/hr each</span></p>
      <p class="text-gray-500 text-xs mb-4">2–3 students, same grade & topic.</p>
      <ul class="space-y-2 text-xs text-gray-600 mb-6 flex-1">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Cheaper per student than solo
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Great for friends or siblings
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-navy-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Same subject & grade required
        </li>
      </ul>
      <a href="/book?plan=group" class="block w-full text-center bg-navy-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-navy-800 transition-colors">Ask about this</a>
    </div>

  </div>

  <!-- Note -->
  <div class="max-w-2xl mx-auto mt-10 text-center reveal">
    <p class="text-gray-500 text-sm leading-relaxed">
      Not sure which option suits you? Send a message on WhatsApp and we can chat about what works best for your situation — there's no pressure either way.
    </p>
  </div>
</section>

<!-- SCHEDULE -->
<section class="bg-navy-50 py-14 px-6">
  <div class="max-w-md mx-auto reveal">
    <p class="text-center text-amber-400 text-sm font-medium tracking-widest uppercase mb-6">Availability</p>
    <div class="bg-white rounded-2xl border border-navy-100 p-6 space-y-3 text-sm">
      <div class="flex justify-between border-b border-navy-50 pb-2">
        <span class="text-gray-500">Monday – Friday</span>
        <span class="text-navy-900 font-medium">14:30 – 19:00</span>
      </div>
      <div class="flex justify-between border-b border-navy-50 pb-2">
        <span class="text-gray-500">Saturday</span>
        <span class="text-navy-900 font-medium">09:30 – 17:00</span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-500">Sunday</span>
        <span class="text-gray-400">Closed</span>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 px-6 bg-white text-center">
  <div class="max-w-xl mx-auto reveal">
    <h2 class="font-display text-3xl font-bold text-navy-900 mb-4">Ready to get started?</h2>
    <p class="text-gray-500 text-sm mb-8">Book your first session — no commitment, just one session to see if it's a good fit.</p>
    <a href="/book" class="inline-block bg-navy-600 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-navy-800 transition-colors">Book a session</a>
  </div>
</section>

<%- include('partials/footer') %>
