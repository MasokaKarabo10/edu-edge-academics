<%- include('partials/header') %>

<section class="bg-navy-900 text-white pt-16 pb-12 px-6 text-center">
  <div class="w-14 h-14 bg-amber-200 rounded-full flex items-center justify-center mx-auto mb-4">
    <svg class="w-7 h-7 text-amber-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
  </div>
  <p class="text-amber-200 text-sm font-medium tracking-widest uppercase mb-3">Almost there</p>
  <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-3">Request received</h1>
  <p class="text-navy-100 max-w-xl mx-auto text-sm sm:text-base">
    Here's a summary of your booking — you can also send it via WhatsApp for a faster reply.
  </p>
</section>

<section class="py-12 px-6 bg-white">
  <div class="max-w-lg mx-auto">

    <!-- Summary card -->
    <div class="border border-navy-100 rounded-2xl p-6 mb-8">
      <p class="text-amber-400 text-xs font-medium tracking-widest uppercase mb-4">Booking summary</p>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Name</dt>
          <dd class="text-navy-900 font-medium"><%= booking.name %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Contact</dt>
          <dd class="text-navy-900 font-medium"><%= booking.contact %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Subject</dt>
          <dd class="text-navy-900 font-medium"><%= booking.subject %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Grade</dt>
          <dd class="text-navy-900 font-medium">Grade <%= booking.grade %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Plan</dt>
          <dd class="text-navy-900 font-medium text-right"><%= booking.planLabel %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Date</dt>
          <dd class="text-navy-900 font-medium"><%= booking.date %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Time</dt>
          <dd class="text-navy-900 font-medium"><%= booking.time %></dd>
        </div>
        <% if (booking.notes) { %>
        <div class="border-t border-navy-50 pt-3">
          <dt class="text-gray-500 mb-1">Notes</dt>
          <dd class="text-navy-900"><%= booking.notes %></dd>
        </div>
        <% } %>
      </dl>
    </div>

    <% if (emailSent) { %>
      <div class="bg-navy-50 rounded-xl p-4 text-center mb-4">
        <p class="text-navy-900 text-sm font-medium mb-1">Email sent successfully</p>
        <p class="text-gray-500 text-xs">You'll be contacted shortly to confirm your session.</p>
      </div>
    <% } else { %>
      <div class="bg-amber-50 rounded-xl p-4 text-center mb-4">
        <p class="text-navy-900 text-sm font-medium mb-1">We couldn't send the email automatically</p>
        <p class="text-gray-500 text-xs">No worries — use the WhatsApp button below instead.</p>
      </div>
    <% } %>

    <!-- WhatsApp option, always available -->
    <a href="<%= whatsappLink %>" target="_blank"
       class="block w-full text-center bg-navy-600 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-navy-800 transition-colors mb-2">
      Send via WhatsApp for a faster reply
    </a>
    <p class="text-gray-400 text-xs text-center">This opens WhatsApp with your details pre-filled — just hit send.</p>

    <div class="text-center mt-8">
      <a href="/" class="text-navy-600 text-sm font-medium hover:text-amber-400 transition-colors">← Back to home</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
